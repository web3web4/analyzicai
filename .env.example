# Environment Variables
# Copy this file to .env.local and fill in your values

# ═══════════════════════════════════════════════════════════════════════
# 🔧 API Logging
# ═══════════════════════════════════════════════════════════════════════
ENABLE_API_LOGGING=true

# =============================================================================
# DEVELOPMENT / TESTING
# =============================================================================

# Node Environment (automatically set by most platforms)
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════
# � Security & Access Control
# ═══════════════════════════════════════════════════════════════════════
# Encryption key for API keys (32-byte hex string - 64 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT USE THE NEXT KEY. GENERATE A NEW ONE WITH THE SAME LENGTH.
ENCRYPTION_KEY=0000000000000000000000000000000800000000000000000000000000000000

# Admin email addresses (comma-separated, auto-promoted to admin on login)
ADMIN_EMAILS=your-admin@example.com,second-admin@example.com

# ═══════════════════════════════════════════════════════════════════════
# 🔑 API Keys
# ═══════════════════════════════════════════════════════════════════════
# Server-side API keys (used as fallback when users don't provide their own)
# Get API keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Anthropic: https://console.anthropic.com/account/keys
# - Google: https://aistudio.google.com/app/apikey

OPENAI_API_KEY=sk-...

ANTHROPIC_API_KEY=sk-ant-...

GEMINI_API_KEY=AI...
# To test your Gemini key:
# curl "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent" \
#   -H 'Content-Type: application/json' \
#   -H 'X-goog-api-key: AI...' \
#   -X POST \
#   -d '{
#     "contents": [
#       {
#         "parts": [
#           {
#             "text": "Explain how AI works in a few words"
#           }
#         ]
#       }
#     ]
#   }'


# ═══════════════════════════════════════════════════════════════════════
# 🤖 AI Model Configuration
# ═══════════════════════════════════════════════════════════════════════
# 
# IMPORTANT: Update these when better performance, fair quality or cheaper models become available!
# - OpenAI pricing: https://openai.com/api/pricing/ & details at https://platform.openai.com/docs/pricing
# - Anthropic pricing: https://anthropic.com/pricing & details at https://platform.claude.com/docs/en/about-claude/pricing
# - Google pricing: https://ai.google.dev/pricing

# Multi-Tier Model Configuration
# Users can select from these tiers based on cost/quality trade-offs
# Tier 1: Cheapest - fastest and most affordable
# Tier 2: Balanced - best cost-to-quality ratio (default)
# Tier 3: Premium - highest quality outcomes

# OpenAI Models
OPENAI_MODEL_TIER_1=gpt-5-nano       # Cheapest
OPENAI_MODEL_TIER_2=gpt-5-mini         # Moderate cost with fair quality
OPENAI_MODEL_TIER_3=gpt-5.2-pro              # Best quality outcomes

# Anthropic Models
ANTHROPIC_MODEL_TIER_1=claude-haiku-4-5-20251001      # Cheapest
ANTHROPIC_MODEL_TIER_2=claude-sonnet-4-5-20250929   # Moderate cost with fair quality
ANTHROPIC_MODEL_TIER_3=claude-opus-4-6       # Best quality outcomes

# Gemini Models
GEMINI_MODEL_TIER_1=gemini-2.0-flash-lite     # Cheapest
GEMINI_MODEL_TIER_2=gemini-2.5-flash       # Moderate cost with fair quality
GEMINI_MODEL_TIER_3=gemini-3-pro-preview       # Best quality outcomes

# Default selected master provider for final synthesis (openai, anthropic, or gemini)
# This provider will be selected by default in the UI
# Note: NEXT_PUBLIC prefix is required for use in client components
NEXT_PUBLIC_DEFAULT_MASTER_PROVIDER=anthropic

# ═══════════════════════════════════════════════════════════════════════
# 📸 Image Upload Configuration
# ═══════════════════════════════════════════════════════════════════════
# Multi-image upload limits (affects both upload and analysis)
# Note: NEXT_PUBLIC prefix is required for use in client components

# Maximum number of images per analysis (default: 10)
NEXT_PUBLIC_MAX_IMAGES=10

# Maximum file size per image in MB (default: 10)
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10

# Maximum total size of all images in MB (default: 50)
NEXT_PUBLIC_MAX_TOTAL_SIZE_MB=50

# ═══════════════════════════════════════════════════════════════════════
# 🗄️ Supabase Configuration
# ═══════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
NEXT_PUBLIC_SUPABASE_PUBLISHABLE=your-anon-key
SUPABASE_SECRET_KEY=your-service-role-key

# ═══════════════════════════════════════════════════════════════════════
# 🔐 OAuth Provider Credentials
# ═══════════════════════════════════════════════════════════════════════
# Social login configuration for Supabase authentication
# 
# CLIENT_ID: Public OAuth identifiers (safe to expose in browser, used by both Supabase and frontend)
#            Set to "ADD_TO_ENABLE" or leave empty to disable a provider
# CLIENT_SECRET: Private keys (backend-only, never exposed to browser)
#
# To enable a provider:
# 1. Get credentials from the provider's developer console
# 2. Set NEXT_PUBLIC_*_CLIENT_ID to your actual client ID
# 3. Set *_CLIENT_SECRET to your actual secret
# 4. Configure callback URLs in provider console (see docs/SUPABASE_SETUP.md)

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=ADD_TO_ENABLE
GOOGLE_CLIENT_SECRET=ADD_TO_ENABLE

# GitHub OAuth
NEXT_PUBLIC_GITHUB_CLIENT_ID=ADD_TO_ENABLE
GITHUB_CLIENT_SECRET=ADD_TO_ENABLE

# Microsoft Azure OAuth
NEXT_PUBLIC_AZURE_CLIENT_ID=ADD_TO_ENABLE
AZURE_CLIENT_SECRET=ADD_TO_ENABLE

# Apple OAuth
NEXT_PUBLIC_APPLE_CLIENT_ID=ADD_TO_ENABLE
APPLE_CLIENT_SECRET=ADD_TO_ENABLE

# Figma OAuth
NEXT_PUBLIC_FIGMA_CLIENT_ID=ADD_TO_ENABLE
FIGMA_CLIENT_SECRET=ADD_TO_ENABLE

# Notion OAuth
NEXT_PUBLIC_NOTION_CLIENT_ID=ADD_TO_ENABLE
NOTION_CLIENT_SECRET=ADD_TO_ENABLE
